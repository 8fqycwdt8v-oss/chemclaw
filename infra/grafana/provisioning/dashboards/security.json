{
  "uid": "chemclaw-security",
  "title": "ChemClaw — Security & redaction",
  "tags": ["chemclaw", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "60s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "MCP auth failures",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"mcp-.+\"} | json | event = \"mcp_auth_failed\" [5m]))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "RLS denials (no user context)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\".+\"} | json | error_code = \"DB_RLS_NO_USER_CONTEXT\" [5m]))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Paperclip budget denials by reason",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (reason) (count_over_time({service=\"paperclip\"} | json | event = \"budget_denied\" [5m]))",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "LiteLLM redaction calls (sampled)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum (count_over_time({service=~\".+\"} | json | event = \"llm_redaction\" [5m]))",
          "refId": "A",
          "legendFormat": "redactions"
        }
      ]
    },
    {
      "id": 5,
      "title": "Recent security events (live)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "{service=~\".+\"} | json | error_code =~ \"MCP_AUTH_FAILED|MCP_SCOPE_DENIED|DB_RLS_DENIED|DB_RLS_NO_USER_CONTEXT|PAPERCLIP_BUDGET_DENIED\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true }
    }
  ]
}
