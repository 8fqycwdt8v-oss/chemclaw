{
  "name": "todo-lifecycle",
  "description": "manage_todos creates and completes a todo. Verifies that step.ts's manage_todos special-case fires onTodoUpdate after each call, surfacing the live checklist to the SSE adapter.",
  "user_messages": ["start the task list"],
  "steps": [
    {
      "llm_response": {
        "kind": "tool_call",
        "toolId": "manage_todos",
        "input": { "action": "create", "contents": ["step 1"] }
      },
      "tool_output": {
        "todos": [
          { "id": "t1", "ordering": 1, "content": "step 1", "status": "in_progress" }
        ]
      }
    },
    {
      "llm_response": {
        "kind": "tool_call",
        "toolId": "manage_todos",
        "input": { "action": "complete", "todo_id": "t1" }
      },
      "tool_output": {
        "todos": [
          { "id": "t1", "ordering": 1, "content": "step 1", "status": "completed" }
        ]
      }
    },
    { "llm_response": { "kind": "text", "text": "Done." } }
  ],
  "expected_events": [
    { "type": "session" },
    { "type": "tool_call", "toolId": "manage_todos" },
    { "type": "tool_result", "toolId": "manage_todos" },
    { "type": "todo_update" },
    { "type": "tool_call", "toolId": "manage_todos" },
    { "type": "tool_result", "toolId": "manage_todos" },
    { "type": "todo_update" },
    { "type": "finish", "finishReason": "stop" }
  ],
  "expected_finish_reason": "stop"
}
