{
  "name": "@chemclaw/agent-claw",
  "version": "0.0.1",
  "private": true,
  "description": "ChemClaw Claw Code — custom harness agent (Phase A.1 skeleton).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:forged": "vitest run tests/unit/ci/forged-tool-ci-check.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ai": "^4.3.19",
    "fastify": "^5.1.0",
    "js-yaml": "^4.1.0",
    "papaparse": "^5.4.1",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.20.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
