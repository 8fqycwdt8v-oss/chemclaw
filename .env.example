# Copy this file to .env and fill in real values. .env is gitignored.

# --------------------------------------------------------------------------
# Postgres (app DB + pgvector + pgvectorscale)
# --------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chemclaw
POSTGRES_USER=chemclaw
POSTGRES_PASSWORD=chemclaw_dev_password_change_me

# --------------------------------------------------------------------------
# Neo4j (bi-temporal KG via Graphiti)
# --------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chemclaw_dev_neo4j_change_me

# --------------------------------------------------------------------------
# Agent service (Node.js / TypeScript / Fastify + Mastra)
# --------------------------------------------------------------------------
AGENT_HOST=0.0.0.0
AGENT_PORT=3100
AGENT_LOG_LEVEL=info

# --------------------------------------------------------------------------
# Frontend (Streamlit)
# --------------------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# --------------------------------------------------------------------------
# LiteLLM (egress chokepoint for external LLM APIs)
# --------------------------------------------------------------------------
LITELLM_HOST=localhost
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-chemclaw-dev-master-change-me

# External LLM provider keys (set the ones you use; others can be blank)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --------------------------------------------------------------------------
# Langfuse (LLM observability)
# --------------------------------------------------------------------------
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --------------------------------------------------------------------------
# Identity (Azure AD / Entra ID — local dev can leave blank)
# --------------------------------------------------------------------------
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=

# --------------------------------------------------------------------------
# Ingestion
# --------------------------------------------------------------------------
# Drop folder for ELN JSON imports
ELN_JSON_DROP_FOLDER=./sample-data/eln-dropbox
# SMB/NAS mount point for document scraping (Phase 1)
SMB_DOCUMENTS_ROOT=

# --------------------------------------------------------------------------
# Dev-only: disable auth to access Streamlit without OIDC for local testing
# --------------------------------------------------------------------------
CHEMCLAW_DEV_MODE=true
CHEMCLAW_DEV_USER_EMAIL=dev@local.test
CHEMCLAW_DEV_USER_PROJECTS=NCE-001,NCE-002
